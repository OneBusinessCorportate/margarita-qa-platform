# ---------------------------------------------------------------------------
# Margarita QA Platform — environment variables
# Copy to .env.local for local dev. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres) ---------------------------------------------------
# Public values are exposed to the browser (anon key, project URL).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used for privileged DB access in API routes / seeding.
# MUST NOT be prefixed with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pooled Postgres connection (port 6543). Only needed for direct SQL / Prisma.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# --- Auth ------------------------------------------------------------------
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# Bootstrap login credentials. Comma-separated "email:password" pairs.
# These always work even before any account is created (e.g. first admin).
# TODO(margarita): retire once real accounts exist in the DB.
AUTH_USERS=info@onebusiness.am:changeme

# Optional: if set, account creation (/register) requires this code. Leave
# unset for open registration.
# SIGNUP_CODE=

# --- Database tables -------------------------------------------------------
# Prefix for this app's tables. The target Supabase project is shared, so the
# default "mqa_" keeps tables isolated from existing ones. Rarely changed.
# DB_TABLE_PREFIX=mqa_

# --- Telegram (later — v1 is copy-to-clipboard only) -----------------------
# When set, a "Send via bot" button can be enabled. Not used in v1.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Google-Sheet link appended to the daily Telegram report message.
REPORT_SHEET_URL=
