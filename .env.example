# ---------------------------------------------------------------------------
# Margarita QA Platform — environment variables
# Copy to .env.local for local dev. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres) ---------------------------------------------------
# Public values are exposed to the browser (anon key, project URL).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used for privileged DB access in API routes / seeding.
# MUST NOT be prefixed with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pooled Postgres connection (port 6543). Only needed for direct SQL / Prisma.
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# --- Auth ------------------------------------------------------------------
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# Bootstrap login credentials. Comma-separated "email:password" pairs.
# These always work even before any account is created (e.g. first admin).
# TODO(margarita): retire once real accounts exist in the DB.
AUTH_USERS=info@onebusiness.am:changeme

# Optional: if set, account creation (/register) requires this code. Leave
# unset for open registration.
# SIGNUP_CODE=

# --- AI: unanswered-chat detection ("Без ответа") --------------------------
# Server-only. Enables the LLM that judges whether a chat genuinely awaits a
# reply (vs a client's closing "спасибо"). Without it, the «Без ответа» page
# falls back to the rule-based signal (client wrote last & not a closing).
# Get a key at https://console.anthropic.com/ . MUST be set on the host.
ANTHROPIC_API_KEY=

# --- Debts ("Долги") source: the OneBusiness debts system ------------------
# Server-only. The SEPARATE Supabase project ("OneBusiness") that automatically
# computes debts (schema ob_app). /api/debts/sync reads from it and mirrors into
# mqa_debts + mqa_chats.debts. Leave unset to keep the manual XLSX import.
ONEBUSINESS_SUPABASE_URL=
ONEBUSINESS_SUPABASE_SERVICE_ROLE_KEY=

# --- Database tables -------------------------------------------------------
# Prefix for this app's tables. The target Supabase project is shared, so the
# default "mqa_" keeps tables isolated from existing ones. Rarely changed.
# DB_TABLE_PREFIX=mqa_

# --- Telegram (later — v1 is copy-to-clipboard only) -----------------------
# When set, a "Send via bot" button can be enabled. Not used in v1.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Google-Sheet link appended to the daily Telegram report message.
REPORT_SHEET_URL=

# --- Live master sheet (clients + debts) -----------------------------------
# The OneBusiness master Google Sheet read LIVE by `npm run sync:sheet` (no
# manual "download as Excel" step). Must be shared as "Anyone with the link can
# view". Falls back to the built-in default in scripts/sync-sheet.ts if unset.
SOURCE_SHEET_URL=https://docs.google.com/spreadsheets/d/1HEy3QVrl-gFUtPAnPRpnKp7ZYEHtksgRBXb5PbtE514/edit
